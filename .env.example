# Copiar a .env.local y llenar con valores reales. Nunca commitear .env* con valores (repo público).

# API de Anthropic — solo se usa server-side (API routes), nunca en el cliente.
ANTHROPIC_API_KEY=

# Supabase — DB de leads, conversaciones y citas (ADR 0003).
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# Dashboard → Settings → API Keys → Secret keys (empieza con sb_secret_).
# ⚠️  Es la clave SECRETA, no la publicable. NO lleva prefijo NEXT_PUBLIC_
#     a propósito: nunca debe llegar al navegador. Las 3 tablas tienen RLS
#     sin policies, así que la publicable no sirve para nada.
SUPABASE_KEY=
